{
	"extends": ["html-validate:document"],
	"rules": {
		"no-dup-attr": "error",
		"no-dup-id": "error",
		"close-attr": "error",
		"close-order": "error",
		"missing-doctype": "error",

		"element-required-attributes": "error",
		"require-sri": "error",
		"heading-level": ["error", { "minInitialRank": "h3" }],
		"input-missing-label": "error",

		"no-deprecated-attr": "error",
		"no-missing-references": "error",
		"no-raw-characters": "error",
		"void-style": "error",

		"deprecated": "error",
		"attr-quotes": "error",
		"attr-case": "error",
		"element-case": "error",
		"void-content": "error",
		"empty-title": "error",
		"text-content": "error",
		"script-element": "error",

		"wcag/h30": "error",
		"wcag/h37": "error",
		"wcag/h63": "error",
		"wcag/h67": "error",
		"wcag/h32": "error",
		"wcag/h71": "error",

		"no-conditional-comment": "error",
		"no-trailing-whitespace": "error",
		"prefer-button": "error",
		"aria-hidden-body": "error",
		"aria-label-misuse": "error",
		"attr-delimiter": "error",
		"map-dup-name": "error",
		"no-redundant-for": "error",
		"svg-focusable": "error",
		"id-pattern": ["error", { "pattern": "^[A-Za-z][A-Za-z0-9_:.-]*$" }]
	}
}

{
	"$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"package.json",
			"biome.json",
			".htmlvalidate.json",
			"linkinator.config.json",
			"index.html",
			"!!css/word-mso.css",
			"!!images",
			"!!**/*.{doc,docx,png,jpg,jpeg,gif,ico,webp}"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineWidth": 120,
		"lineEnding": "lf"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"a11y": {
				"recommended": false
			},
			"correctness": {
				"noUnknownProperty": "off"
			},
			"suspicious": {
				"noUnknownAtRules": "off",
				"noUselessEscapeInString": "off"
			},
			"complexity": {
				"noImportantStyles": "off"
			}
		}
	},
	"html": {
		"formatter": {
			"enabled": true
		}
	},
	"css": {
		"linter": {
			"enabled": true
		},
		"parser": {
			"cssModules": false
		}
	},
	"json": {
		"formatter": {
			"trailingCommas": "none"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
